<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body data-api-base-url="<%= apiBaseUrl %>" data-platform-status="<%= platformStatus %>">
    <%- include('partials/topbar', { apiBaseUrl, platformStatus }) %>

    <main class="container auth-layout auth-layout--single">
      <section class="service-section auth-card">
        <h2>Registrar - Paso 1</h2>
        <p class="small-note">Ingresa tu correo y contrasena para continuar.</p>
        <form id="register-step1-form" class="stack-form">
          <label>Correo <input name="email" type="email" required /></label>
          <label>Contrasena <input name="password" type="password" minlength="8" required /></label>
          <button type="submit" class="btn-primary">Continuar</button>
        </form>
      </section>

      <p id="register-step1-message" class="small-note"></p>
    </main>

    <script src="/js/register-step1.js"></script>
    <script src="/js/session-ui.js"></script>
  </body>
</html>
