<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body data-api-base-url="<%= apiBaseUrl %>" data-platform-status="<%= platformStatus %>">
    <%- include('partials/topbar', { apiBaseUrl, platformStatus }) %>

    <main class="container main-content">
      <div class="page-back-nav">
        <a class="back-link" href="/">Volver al inicio</a>
      </div>
      <div class="config-layout">
        <%- include('partials/config-sidebar', { activeConfigSection }) %>

        <section class="service-section config-content">
          <h1>Usuarios registrados</h1>
          <input id="users-search" class="text-input" placeholder="Buscar usuario/correo/rol..." />
          <div class="users-table-wrap">
            <table id="users-table" class="users-table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Usuario</th>
                  <th>Correo</th>
                  <th>Rol</th>
                  <th>Creado</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="users-table-body"></tbody>
            </table>
          </div>
          <p id="config-message" class="small-note"></p>
        </section>
      </div>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/config-utils.js"></script>
    <script src="/js/config-usuarios.js"></script>
    <script src="/js/session-ui.js"></script>
  </body>
</html>
