<header class="topbar" data-api-base-url="<%= apiBaseUrl %>">
  <div class="topbar__inner">
    <% const currentStatus = platformStatus || 'ACTIVA'; %>
    <div class="topbar__brand-wrap">
      <a href="/" class="topbar__brand">Skirk Boost</a>
      <span class="status-indicator topbar__status <%= currentStatus === 'ACTIVA' ? 'status-green' : currentStatus === 'PARCIAL' ? 'status-yellow' : 'status-red' %>">
        <%= currentStatus %>
      </span>
    </div>
    <nav class="topbar__actions">
      <a href="/carrito" class="cart-link" aria-label="Abrir carrito">
        <span class="cart-link__icon">Carrito</span>
        <span id="cart-count" class="cart-link__badge">0</span>
      </a>
      <a href="/login" id="login-link" class="topbar__link">Ingresar</a>
      <a href="/registro" id="register-link" class="topbar__link">Registrar</a>
      <div id="session-menu" class="session-menu hidden">
        <button
          id="session-menu-toggle"
          class="session-menu__toggle"
          type="button"
          aria-haspopup="true"
          aria-expanded="false"
        >
          <span id="session-menu-label">Usuario</span>
        </button>
        <div id="session-menu-dropdown" class="session-menu__dropdown" role="menu"></div>
      </div>
    </nav>
  </div>
</header>
