<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body data-api-base-url="<%= apiBaseUrl %>" data-platform-status="<%= platformStatus %>">
    <%- include('partials/topbar', { apiBaseUrl, platformStatus }) %>

    <main class="container main-content">
      <div class="page-back-nav">
        <a class="back-link" href="/">Volver al inicio</a>
      </div>
      <div class="config-layout">
        <%- include('partials/config-sidebar', { activeConfigSection }) %>

        <section class="service-section config-content">
          <h1>Configuracion de plataforma</h1>
          <div id="status-indicator" class="status-indicator status-green">ACTIVA</div>

          <div class="status-actions">
            <button class="btn-secondary js-status" data-value="ACTIVA">Activa</button>
            <button class="btn-secondary js-status" data-value="PARCIAL">Parcial</button>
            <button class="btn-secondary js-status" data-value="NO_ACTIVA">No activa</button>
          </div>

          <p id="config-message" class="small-note"></p>
        </section>
      </div>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/config-utils.js"></script>
    <script src="/js/config-home.js"></script>
    <script src="/js/session-ui.js"></script>
  </body>
</html>
