<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body data-api-base-url="<%= apiBaseUrl %>" data-platform-status="<%= platformStatus %>">
    <%- include('partials/topbar', { apiBaseUrl, platformStatus }) %>

    <main class="container main-content">
      <div class="page-back-nav">
        <a class="back-link" href="/">Volver al inicio</a>
      </div>
      <div class="config-layout">
        <%- include('partials/config-sidebar', { activeConfigSection }) %>

        <section class="service-section config-content">
          <h1>Pedidos</h1>
          <div class="cards-inline">
            <input id="orders-search" class="text-input" placeholder="Filtrar por ID, usuario o correo..." />
            <select id="orders-status-filter" class="text-input">
              <option value="">Todos los estados</option>
              <option value="PENDING">Pendiente</option>
              <option value="NOTIFIED">Notificado</option>
              <option value="IN_PROGRESS">En progreso</option>
              <option value="COMPLETED">Completado</option>
              <option value="FAILED_NOTIFY">Fallo notificacion</option>
              <option value="CANCELLED">Cancelado</option>
            </select>
          </div>
          <div class="users-table-wrap">
            <table id="orders-table" class="users-table">
              <thead>
                <tr>
                  <th>Order ID</th>
                  <th>Usuario</th>
                  <th>Correo</th>
                  <th>Servicios solicitados</th>
                  <th>Total</th>
                  <th>Notificacion</th>
                  <th>Actualizado</th>
                  <th>Estado</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="orders-table-body"></tbody>
            </table>
          </div>
          <p id="config-message" class="small-note"></p>
        </section>
      </div>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/config-utils.js"></script>
    <script src="/js/config-pedidos.js"></script>
    <script src="/js/session-ui.js"></script>
  </body>
</html>
