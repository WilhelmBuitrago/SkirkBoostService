<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body data-api-base-url="<%= apiBaseUrl %>" data-platform-status="<%= platformStatus %>">
    <%- include('partials/topbar', { apiBaseUrl, platformStatus }) %>

    <main class="container main-content">
      <div class="page-back-nav">
        <a class="back-link" href="/">Volver al inicio</a>
      </div>
      <div class="config-layout">
        <%- include('partials/config-sidebar', { activeConfigSection }) %>

        <section class="service-section config-content">
          <h1>Servicios deshabilitados en modo parcial</h1>
          <input id="service-search" class="text-input" placeholder="Buscar servicio..." />
          <div id="service-checklist" class="cards-inline"></div>
          <p id="config-message" class="small-note"></p>
        </section>
      </div>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/config-utils.js"></script>
    <script src="/js/config-servicios.js"></script>
    <script src="/js/session-ui.js"></script>
  </body>
</html>
