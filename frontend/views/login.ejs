<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body data-api-base-url="<%= apiBaseUrl %>" data-platform-status="<%= platformStatus %>">
    <%- include('partials/topbar', { apiBaseUrl, platformStatus }) %>

    <main class="container auth-layout auth-layout--single">
      <section class="service-section auth-card">
        <h2>Ingresar</h2>
        <form id="login-form" class="stack-form">
          <label>Correo o usuario (solo admin) <input name="identifier" required /></label>
          <label>Contrasena <input name="password" type="password" required /></label>
          <p class="small-note auth-note">Aun no tienes una cuenta? <a href="/registro">Registrate aqui</a></p>
          <button type="submit" class="btn-primary">Ingresar</button>
        </form>
      </section>

      <p id="auth-message" class="small-note"></p>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/auth.js"></script>
    <script src="/js/session-ui.js"></script>
  </body>
</html>
