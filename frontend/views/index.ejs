<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body data-exchange-rate="<%= exchangeRate %>" data-api-base-url="<%= apiBaseUrl %>" data-platform-status="<%= platformStatus %>">
    <%- include('partials/topbar', { apiBaseUrl, platformStatus }) %>
    <div class="app-shell"></div>
    <header class="hero">
      <div class="hero__overlay"></div>
      <div class="hero__content container">
        <p class="hero__subtitle">Genshin Impact Customer Service</p>
        <h1>Skirk's Boost Service</h1>
        <p class="hero__desc">
          Te ayudamos con el progreso de tu cuenta, desde misiones hasta farmeo de recursos. ¡Servicios personalizados para cada necesidad!
        </p>
        <!-- <a class="btn-primary" href="/exploracion">Ir a exploracion</a> -->
      </div>
    </header>

    <main class="container main-content">
      <section class="service-section">
        <div class="section-head">
          <h2>Servicios principales</h2>
          <!-- <p>Home didactica con 6 opciones. Cada bloque te lleva a una pagina dedicada.</p> -->
        </div>
        <div class="service-grid">
          <% serviceCards.forEach((card) => { %>
          <article class="service-hub-card">
            <a href="<%= card.href %>" class="service-hub-card__link">
              <p class="service-hub-card__kicker">Servicio</p>
              <h3><%= card.title %></h3>
              <p><%= card.description %></p>
              <div class="service-hub-card__meta"><%= card.meta %></div>
              <!-- <span class="service-hub-card__action">Ver detalle</span> -->
            </a>
          </article>
          <% }) %>
        </div>
      </section>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/main.js"></script>
    <script src="/js/session-ui.js"></script>
  </body>
</html>
