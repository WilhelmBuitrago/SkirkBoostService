<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body data-api-base-url="<%= apiBaseUrl %>" data-platform-status="<%= platformStatus %>">
    <%- include('partials/topbar', { apiBaseUrl, platformStatus }) %>

    <main class="container main-content">
      <section class="service-section">
        <h1>Perfil y pedidos</h1>
        <p id="perfil-message" class="small-note"></p>
        <div id="perfil-user" class="summary-box hidden"></div>
      </section>

      <section class="service-section">
        <h2>Pedidos pasados</h2>
        <div class="users-table-wrap">
          <table class="users-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Servicios solicitados</th>
                <th>Estado</th>
                <th>Fecha</th>
              </tr>
            </thead>
            <tbody id="orders-table-body"></tbody>
          </table>
        </div>
      </section>
    </main>

    <script src="/js/perfil.js"></script>
    <script src="/js/session-ui.js"></script>
  </body>
</html>
